# bandcamp-warden — copy to .env on the TrueNAS host and fill in.
# This file is gitignored. Don't commit a populated .env.

# --- Telegram (required) ---
# Create a bot via @BotFather, send it /start in your Telegram client, then
# call https://api.telegram.org/bot<TOKEN>/getUpdates to find your chat id.
TELEGRAM_BOT_TOKEN=123456789:replace-with-real-token
TELEGRAM_CHAT_ID=000000000

# --- TrueNAS host paths (recommended defaults shown) ---
# Music output. Should be a dataset on a roomy pool.
HOST_DOWNLOADS_PATH=/mnt/storage/media/bandcamp
# bandcampsync state — cookies.txt + ignores.txt live here.
HOST_CONFIG_PATH=/mnt/apps/bandcamp-warden/config
# Sidecar state — SQLite db lives here.
HOST_STATE_PATH=/mnt/apps/bandcamp-warden/state

# --- Schedule ---
# Hour (0–23) at which the daily kickoff fires. Default 03:00 = low traffic.
DAILY_RUN_HOUR=3
TIMEZONE=Europe/Berlin

# --- Ramp-up ---
# Albums allowed per day, ramping up. Last value repeats indefinitely.
# Day 1: 30, Day 2: 100, Day 3+: 200.
# To start with an even smaller pilot, prepend e.g. [5, 30, 100, 200].
RAMP_QUOTAS=[30, 100, 200]

# --- bandcampsync image + ownership ---
BANDCAMPSYNC_IMAGE=ghcr.io/meeb/bandcampsync:latest
# UID/GID that bandcampsync writes files as. On TrueNAS Scale, the apps user
# is typically 568 (group apps). Adjust if your music dataset has different
# ownership requirements.
BANDCAMPSYNC_PUID=568
BANDCAMPSYNC_PGID=568

# --- Cookie expiry monitoring ---
# Telegram warning fires once per day when the bandcamp identity cookie
# is closer than this many days to its hard server-set expiry.
# Only catches the ~1-year hard expiry. Spontaneous server-side
# invalidation (password change, "sign out everywhere", anti-abuse flag)
# is caught by the anomaly detector via 401/403 responses, not here.
COOKIE_WARN_THRESHOLD_DAYS=14

# --- Plan E: browser-extension-driven downloads ---
# Turn on the inbox watcher: sidecar polls /downloads/_inbox/, processes
# ZIPs that the Plan-E Firefox extension drops there.
INBOX_WATCHER_ENABLED=false
# When the extension fully owns downloads, set this to false to stop
# the daily bandcampsync container kickoff. Keep true while validating
# Plan E in parallel with the legacy path.
DAILY_KICKOFF_ENABLED=true
# Shared secret for the /inbox/upload HTTP endpoint. When empty, the
# endpoint is disabled (returns 503). Generate a long random string,
# e.g.:  python3 -c 'import secrets; print(secrets.token_urlsafe(32))'
# Put the same value in the extension's Options page.
INBOX_UPLOAD_AUTH_TOKEN=
