{
    "manifest_version": 2,
    "name": "Bandcamp Warden Helper",
    "version": "0.1.0",
    "description": "Downloads your Bandcamp collection at a humane pace using your real browser identity.",
    "author": "idleherb",
    "browser_specific_settings": {
        "gecko": {
            "id": "warden-helper@idleherb.bandcamp-warden",
            "strict_min_version": "115.0"
        }
    },
    "permissions": [
        "storage",
        "alarms",
        "downloads",
        "https://bandcamp.com/*",
        "https://*.bandcamp.com/*"
    ],
    "optional_permissions": [
        "http://*/*",
        "https://*/*"
    ],
    "background": {
        "scripts": ["src/background/index.ts"],
        "persistent": true
    },
    "options_ui": {
        "page": "src/options/options.html",
        "open_in_tab": true
    },
    "browser_action": {
        "default_icon": {
            "16": "icons/16.png",
            "32": "icons/32.png"
        },
        "default_title": "Bandcamp Warden"
    },
    "icons": {
        "16": "icons/16.png",
        "32": "icons/32.png",
        "128": "icons/128.png"
    }
}
